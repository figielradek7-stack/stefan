# GPU/CPU Configuration
DEVICE=cuda
PRECISION=fp16

# Model Configuration
MODEL_ID=stabilityai/stable-diffusion-xl-base-1.0
REFINER_ID=stabilityai/stable-diffusion-xl-refiner-1.0
USE_REFINER=true

# Safety & NSFW
ENABLE_NSFW_FILTER=true
NSFW_THRESHOLD=0.5

# Generation Defaults
DEFAULT_STEPS=50
DEFAULT_GUIDANCE_SCALE=7.5
DEFAULT_HEIGHT=768
DEFAULT_WIDTH=512
SEED=-1

# LoRA Configuration
LORA_RANK=64
LORA_ALPHA=64
LORA_DROPOUT=0.1

# DreamBooth Configuration
DREAMBOOTH_LEARNING_RATE=1e-4
DREAMBOOTH_EPOCHS=100
DREAMBOOTH_BATCH_SIZE=2

# Face Embedding
FACE_DETECTION_CONFIDENCE=0.9
FACE_EMBEDDING_DIM=512

# UI Configuration
UI_HOST=0.0.0.0
UI_PORT=7860
UI_SHARE=false
UI_DEBUG=false

# Paths
OUTPUT_DIR=./outputs
MODELS_DIR=./models
CACHE_DIR=./cache

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/stefan.log

# HuggingFace Token (optional, for private models)
HUGGINGFACE_TOKEN=
